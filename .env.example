# Copy to .env and fill in. Values prefixed EXPO_PUBLIC_* are inlined into the
# client bundle at build time, so they are NOT secrets (do not put real secrets here).

# Sentry DSN — public by design (ships in the client bundle).
EXPO_PUBLIC_SENTRY_DSN=

# GSAV hosting web origin the shell loads. Drives BOTH the native WebView and the
# web build's handoff/redirect, so they stay consistent. Defaults to
# http://127.0.0.1:5191 (gsav-hosting local-deploy preview). For raw Vite dev with
# hot reload + SPA routing, use http://localhost:5173. MUST be the real https origin
# for production builds (see scripts/verify-native-production-config.js).
EXPO_PUBLIC_GSAV_WEB_URL=

# diveo catalog API (World B native browse) — the native feed/search/creator read
# content from gsav-hosting's catalog Edge Function. Defaults to the local dev
# functions endpoint. The Supabase anon key is public by design (safe to ship);
# get the local value from `supabase status` in gsav-hosting.
EXPO_PUBLIC_GSAV_CATALOG_URL=
EXPO_PUBLIC_GSAV_SUPABASE_ANON_KEY=

# App environment: "production" disables Android cleartext traffic (see app.config.js).
EXPO_PUBLIC_APP_ENV=
